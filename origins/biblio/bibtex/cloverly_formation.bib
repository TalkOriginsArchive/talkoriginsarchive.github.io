    year = "1998",
    journal = "Journal of Vertebrate Paleontology",
    abstract = "(1998). Triconodont mammals from the Cloverly Formation (Lower Cretaceous), Montana and Wyoming. Journal of Vertebrate Paleontology: Vol. 18, No. 1, pp. 237-241.",
