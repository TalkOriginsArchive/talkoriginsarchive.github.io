@article{doi1054080022136834110,
    author = "Zenger, Donald H.",
    title = "Lyell and Episodicity",
    year = "1986",
    journal = "Journal of Geological Education",
    abstract = "The philosophy of episodicity has become popular and it is fashionable to censure Lyellian uniformitarianism. Although appreciating the significance of dynamic events in geology (Zenger, 1970), I submit that episodicity has been somewhat overplayed. Lyell's “Principles of Geology” reveals that he clearly recognized episodicity. His use of “gradual” was broader than ours and embraced episodic physical events, in contrast to the truly cataclysmic occurrences of the catastrophists, against whom he was waging an intense philosophical battle. His elegant description (1830, p. 79) of episodic movements along faults resulting in the “gradual” uplift of mountain chains is a clear statement of this view. Also indicating his acceptance of episodic events are his discussions of intense earthquake or volcanic activity in a region followed by long periods of tranquillity, the approaches of comets, and the occurrence of violent floods and storms. Furthermore, advocating “the past operation of causes now in action,” Lye...",
    url = "https://doi.org/10.5408/0022-1368-34.1.10",
    doi = "10.5408/0022-1368-34.1.10",
    openalex = "W2518254326"
}

