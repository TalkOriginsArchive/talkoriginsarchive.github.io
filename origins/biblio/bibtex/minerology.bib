@article{doi101016jrgg201503010,
    author = "Sennikov, N. V. and Tolmacheva, T. Yu. and Obut, O.T. and Изох, Н. Г. and Lykova, E. V.",
    title = "Zonation of the Siberian Ordovician deposits based on pelagic groups of fauna",
