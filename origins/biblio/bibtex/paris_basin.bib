@article{larue2000les,
    author = "Larue, Jean-Pierre",
    title = "Les réorganisations hydrographiques du bassin du Cher dans le sud du Bassin parisien (France) / Drainage pattern modifications in the Cher Basin, southern Paris Basin (France)",
    year = "2000",
    journal = "Géomorphologie relief processus environnement",
    abstract = "Résumé Dans le sud du Bassin parisien, le réseau hydrographique s'est installé sur une paléosurface imparfaite inclinée vers la Sologne. Du Miocène au Pliocène supérieur, cette surface a servi au transit de formations détritiques issues du Massif central. Deux amples gouttières axées sur l'Arnon et le Cher n'ont pas empêché les défluviations, à tel point que la confluence des paléo-Arnon et Cher a migré du sud de Saint-Florent à Vierzon. Datées pour l'essentiel du Pliocène supérieur par la présence de minéraux volcaniques, les formations détritiques ont contrarié l'incision des cours d'eau secondaires, mais les bifurcations brusques des ruisseaux du Boeuf et de la Loubière sont probablement dues à la tectonique. L'encaissement des rivières, plus rapide après la mise en place de la haute terrasse, s'est accompagné de captures affectant principalement l'Arnon, la Marmande et les petits affluents de rive gauche du Cher. Réalisées pendant les phases de creusement qui précèdent les périodes froides, elles s'expliquent par des conditions morphostructurales locales et par les rejeux tectoniques des linéaments de direction N 60 et N 160-170.",
    url = "https://doi.org/10.3406/morfo.2000.1051",
    doi = "10.3406/morfo.2000.1051",
    number = "2",
    pages = "105-123",
    volume = "6"
}

@misc{andlecoulsNoneles,
    author = "Le Couls, Matthieu",
    title = "Les paléoflores du Jurassique moyen et supérieur (Bathonien - Oxfordien) du bassin parisien et de ses marges",
    year = "None",
    abstract = "La paléoflore du Jurassique moyen et supérieur du bassin parisien est documentée par un ensemble de gisements assez importants et relativement peu connus, contenant des fossiles de tous types, généralement sous forme d’empreintes avec ou sans cuticule, ou encore sous forme de silicification dans des chailles. Huit gisements historiques ou nouveaux ont été étudiés, plus quatre fossiles isolés, tous datant de l’intervalle Bathonien-Oxfordien, et répartis sur l’ensemble du bassin parisien et de ses marges. Trois gisements ont étés étudiés dans la partie Est du bassin, Il s’agit d’Arc-en-Barrois (Bathonien supérieur), d’Étrochey (Callovien inférieur et moyen) et de Laignes (Callovien moyen). Ils appartiennent tous à l’archipel de la plate-forme bourguignonne, dont les îles étaient alors couvertes d’une forêt mixte xérophytes à Brachyphyllum. Le gisement d’Auxey, situé plus au sud, près de Beaune, daté de l’Oxfordien supérieur, montre au contraire une flore de milieu humide, riche en fougères. Deux autres gisements ont été étudiés au niveau du seuil du Poitou, les flores du Callovien moyen de Sauzé-Vaussais et des environs de Poitiers, riches en bennettitales, correspondant probablement à des milieux xéromorphes assez ouverts. Enfin, deux derniers gisements ont étés étudiés dans l’ouest du bassin, sur la marge orientale du massif armoricain alors émergé, les flores du Bathonien supérieur de Mamers et de Nonant-le-Pin. Ces deux gisements correspondent à des forêts mixtes côtières à Brachyphyllum, dans un milieu également xéromorphe. Ainsi, le bassin parisien présente au Bathonien et au Callovien exclusivement des flores côtières xérophytes, correspondant à des paléoenvironnements plutôt fermés, comme sur la plate-forme bourguignonne, jusqu’à des milieux au contraire assez ouverts, comme dans le Poitou. Les flores de milieu interne, loin des côtes, ne sont pas connues pour cette période. À l’Oxfordien supérieur en revanche, la flore d’Auxey indiquerait plutôt une certaine humidification du climat, bien que de plus amples données soient nécessaires pour confirmer cette interprétation.",
    url = "https://doi.org/10.70675/eb4da98dz77d7z456dzaaf8zb543c814ad10",
    doi = "10.70675/eb4da98dz77d7z456dzaaf8zb543c814ad10"
}
