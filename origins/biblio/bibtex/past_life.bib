    doi = "10.5204/mcj.2793",
    is_oa = "true",
    number = "5",
    semanticscholar_citation_count = "4",
    semanticscholar_id = "58804e1705bb7ba03d839eb38d26ec3ec9f2b91c",
    volume = "24"
