@article{hideyukiogawa1999selfassembly,
    author = "Hideyuki Ogawa, Hideyuki Ogawa and Takumi Takamura, Takumi Takamura and Yuhei Shimoyama, Yuhei Shimoyama",
    title = "Self-Assembly Process of Alkanethiol Monolayers",
    year = "1999",
    journal = "Japanese Journal of Applied Physics",
    abstract = "To reveal formation of self-assembled monolayers (SAM), we analyzed the molecular orientation of SAMs of alkanethiol and the molecular organization in the Langmuir-Blodgett (LB) and vacuum deposited (VD) films by Fourier-transform infrared reflection absorption spectroscopy (FT-IR-RAS) and X-ray diffraction (XRD). XRD of the LB films suggests that alkanethiol orients normal to a gold substrate. Alkanethiol in the VD films tilts with a larger angle on the gold than on the glass substrates. The FT-IR-RAS spectra revealed that the molecular organization in the SAM on the gold (111) surface is dependent on the immersion time. Alkanethiol in the SAM aligns normal to the substrate, when the molecule undergoes close packing. A stable SAM embedded in a well-ordered monolayer is controlled by the intermolecular interaction of alkanethiol as well as the interaction between sulfur and gold.",
    url = "https://doi.org/10.1143/jjap.38.6019",
    doi = "10.1143/jjap.38.6019",
    number = "10R",
    pages = "6019",
    volume = "38"
}

