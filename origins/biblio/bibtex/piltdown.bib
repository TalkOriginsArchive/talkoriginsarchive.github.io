@misc{smith2018piltdown,
    author = "Smith, Fred H.",
    title = "Piltdown",
    year = "2018",
    booktitle = "The International Encyclopedia of Biological Anthropology",
    abstract = "The Piltdown forgery is likely the most well‐known hoax in the history of science. The scientific unveiling of the Piltdown skull in 1912 set in motion a series of events that impacted the study of human evolution for 40 years. Classified as “ Eoanthropus dawsoni ” and hailed as “The First Englishman,” Piltdown was supported by many scholars but questioned by many others. Accumulating scientific information ultimately led to the exposure of the forgery and the end of the Piltdown question in 1953. Though often cited as a criticism of the efficacy of human evolutionary studies, Piltdown actually serves as an excellent example of the self‐correcting nature and methodological approach of science.",
    url = "https://doi.org/10.1002/9781118584538.ieba0383",
    doi = "10.1002/9781118584538.ieba0383",
    pages = "1-3"
}

