@article{ríosmalváez2024quinoline,
    author = "Ríos-Malváez, Zita G. and González-Rivas, Nelly and Cuevas-Yañez, Erick",
    title = "Quinoline Hydroxyalkylations from Iron-Catalyzed, Visible-Light-Driven Decarboxylations",
    year = "2024",
    journal = "Catalysts",
    abstract = "One of the current challenges in organic synthesis is the direct alkylation of heterocyclic systems with a minimal impact on the environment. In this report, 4-substituted hydroxyalkyl quinolines were obtained by treating quinoline with different alkyl carboxylic acids in the presence of catalytic amounts of an iron (III) chloride–phenanthroline complex. The reaction was mediated by blue LED light under acidic conditions as a cleaner alternative to conventional heating, reducing the use of harmful substances.",
    url = "https://doi.org/10.3390/catal14120916",
    doi = "10.3390/catal14120916",
    number = "12",
    pages = "916",
    volume = "14"
}
