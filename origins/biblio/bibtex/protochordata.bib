@article{pmid12548775,
    author = "Fang, Y Q and Weng, Y Z and Chen, L",
    title = "[Distribution of luteinizing hormone (LH) and human chorionic gonadotropin (hCG) in the nervous system, Hatschek's pit and gonads of protochordata].",
    year = "1999",
    journal = "Shi yan sheng wu xue bao",
    abstract = "Immunocytochemical localization of the nervous system, Hatschek's pit and gonads in protochordata was carried out using two specific antibodies against human LH and hCG. The results indicate that there are two different kinds of LH- and hCG-like immunopositive cells in the brain vesicle and nerve tuber of amphioxus, and nerve ganglion in Styela plicata showed immuno-negative reaction to LH and hCG antibodies. At the same time, we found for the first time that LH- and hCG-like immuno-positive cells existed in the early gonads (ovaries and testis) in protochordata. Positive substance distributed in the cytoplasm, nucleoplasm and nucleolar membrane of oogonia as well as early spermatogenic cells in testis. Afterwards, this positive substance was still distributed in the cytoplasmic membrane, cytoplasm, nuclear membrane and nucleoplasm of oocyte during the development and maturation of ovary, and spermatid and spermatozoa showed immuno-negative reaction in testis. These results will provide a new mophological proof that LH and hCG may be directly involved in regulation of the gonadal development and maturation of protochordata.",
    url = "https://pubmed.ncbi.nlm.nih.gov/12548775/",
    pmid = "12548775"
}
