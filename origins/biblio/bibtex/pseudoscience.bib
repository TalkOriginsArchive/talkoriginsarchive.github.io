@incollection{stea2024the,
    author = "Stea, Jonathan N.",
    title = "The Evolution and Seduction of Pseudoscience",
    year = "2024",
    booktitle = "Mind the Science",
    abstract = "This chapter details the evolution and seduction of mental health–related pseudoscience. It begins by providing historical and modern-day examples of snake oil, couching them in the context of the author’s personal and clinical experiences. It illustrates the nature of pseudoscience, delineating between unequivocal cases (e.g., naturopathy, energy healing) and controversial ones that are more scientifically plausible but still plagued by some pseudoscientific features and low-quality evidence to support their use (e.g., mindfulness meditation, psychedelics). It goes on to show the reasons that we find pseudoscience attractive, foreshadowing the commercialization of pseudoscience in the wellness and alternative medicine industries. The chapter closes with real examples about the various ways that pseudoscience is harmful to our mental health.",
    url = "https://doi.org/10.1093/oso/9780197748817.003.0002",
    doi = "10.1093/oso/9780197748817.003.0002",
    pages = "7-23"
}
