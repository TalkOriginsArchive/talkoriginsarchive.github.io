@article{ochsenius1884vmetalliferous,
    author = "Ochsenius, Carl",
    title = "V.—Metalliferous Deposits",
    year = "1884",
    journal = "Geological Magazine",
    abstract = "The origin of metalliferous deposits has long been a subject of discussion. Professor Joseph Le Conte, however, seems to have arrived at a very decided opinion on this question, for in a contribution to the “American Journal of Science” (3rd series, xxvi. p. 1—19, July, 1883), after referring to Sulphur Banks and Steamboat Springs in California, he says: “Thus then subterranean waters of any kind, but especially alkaline, at any temperature, but mostly hot, circulating in any direction, but mainly upcoming, and in any kind of waterway, but mainly in open fissures, by deposit, form metalliferous veins.”",
    url = "https://doi.org/10.1017/s0016756800005276",
    doi = "10.1017/s0016756800005276",
    number = "7",
    pages = "310-318",
    volume = "1"
}

