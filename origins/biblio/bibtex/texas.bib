@article{olander1985wilcox,
    author = "Olander, A. M.",
    title = "Wilcox Depth Prediction at Katy Field, Waller County, Texas: Problem and Solution: ABSTRACT",
    year = "1985",
    journal = "AAPG Bulletin",
    abstract = "Velocity anomalies large enough to cause severe errors in depth maps may not be recognized from prior drilling experience, from regional velocity control, or from seismic reflection configurations. A chastening example of one such anomaly is an outpost well near the Katy field in Waller County, Texas. This outpost well, the Exxon 1 Sparks, tested Wilcox sands, which were both dry and 500 ft low to seismic prediction from Vibroseis data. The well came in structurally low as a result of incorrect predictions of both near-surface and post-Wilcox velocities. Additional studies indicated that the Sparks well was drilled on the flank of a structure that was later drilled and proved to be the discovery of a new Wilcox field. Accurate velocities are becoming increasingly important in all phases of oil and gas exploration, particularly in mature exploration areas where prospects are subtle and difficult to find.",
    url = "https://doi.org/10.1306/ad462281-16f7-11d7-8645000102c1865d",
    doi = "10.1306/ad462281-16f7-11d7-8645000102c1865d",
    number = "2",
    pages = "294-294",
    volume = "69"
}

