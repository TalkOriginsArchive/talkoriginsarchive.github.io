@article{livingstone1962vertical,
    author = "Livingstone, D. A. and Boykin, J. C.",
    title = "VERTICAL DISTRIBUTION OF PHOSPHORUS IN LINSLEY POND MUD",
    year = "1962",
    journal = "Limnology and Oceanography",
    abstract = "Acid extraction, digestion, and water dilution experiments disclose the presence of large quantities of phosphorus in the basal third of the sedimentary section from Linsley Pond, Connecticut. The results suggest, but do not prove, that sedimentary phosphorus is bound largely by sorption reactions with mineral material. If this is so, then changes in productivity of the developing lake, and differences in lake productivity generally, may be determined by sorption reactions in the surface mud. For any kind of sorption reaction the productivity would be inversely proportional to the sorptive capacity of the mud, and for ion exchange it would also be directly proportional to the total ionic activity of the water.",
    url = "https://doi.org/10.4319/lo.1962.7.1.0057",
    doi = "10.4319/lo.1962.7.1.0057",
    number = "1",
    pages = "57-62",
    volume = "7"
}

